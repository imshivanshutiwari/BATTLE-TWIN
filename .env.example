# BATTLE-TWIN Environment Variables
# Copy to .env and fill in values

# OpenAI API key for LangGraph agents
OPENAI_API_KEY=

# OpenWeatherMap API key (free tier)
OPENWEATHER_API_KEY=

# Copernicus Open Access Hub (Sentinel-2)
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# NATS Server
NATS_TOKEN=
NATS_USER=
NATS_PASSWORD=

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=battle-twin

# Dashboard
DASH_PORT=8050
DASH_DEBUG=false
